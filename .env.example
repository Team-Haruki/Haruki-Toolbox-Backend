COMPOSE_PROJECT_NAME=haruki-toolbox
BACKEND_IMAGE=ghcr.io/team-haruki/haruki-toolbox-backend:latest
ORY_VERSION=v25.4.0
POSTGRES_PORT=5432
REDIS_PORT=6379
KRATOS_PUBLIC_PORT=4433
KRATOS_ADMIN_PORT=4434
OATHKEEPER_PROXY_PORT=4455
BACKEND_PORT=16666
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
STACK_HOST_ROOT=/path/to/stack/host/root
AVATAR_STORAGE_PATH=/path/to/avatar/storage
POSTGRES_DATA_PATH=/path/to/postgres/data
REDIS_DATA_PATH=/path/to/redis/data
MONGO_DATA_PATH=/path/to/mongo/data
POSTGRES_PASSWORD=change-me-postgres-password
REDIS_PASSWORD=change-me-redis-password
MONGO_ROOT_USERNAME=change-me-mongo-root-username
MONGO_ROOT_PASSWORD=change-me-mongo-root-password
MONGODB_DB=change-me-mongodb-database
MONGODB_SUITE_COLLECTION=change-me-mongodb-suite-collection
MONGODB_MYSEKAI_COLLECTION=change-me-mongodb-mysekai-collection
KRATOS_DB_USER=change-me-kratos-db-user
KRATOS_DB_PASSWORD=change-me-kratos-db-password
HYDRA_DB_USER=change-me-hydra-db-user
HYDRA_DB_PASSWORD=change-me-hydra-db-password
HARUKI_DB_USER=change-me-haruki-db-user
HARUKI_DB_PASSWORD=change-me-haruki-db-password
HARUKI_BOT_DB_URL=postgresql://user:password@host:5432/haruki_bot?sslmode=disable
HARUKI_BOT_ENABLE_REGISTRATION=false
HARUKI_BOT_CREDENTIAL_SIGN_TOKEN=change-me-bot-credential-sign-token
KRATOS_COOKIE_SECRET=change-me-kratos-cookie-secret
KRATOS_CIPHER_SECRET=change-me-kratos-cipher-secret
HYDRA_SYSTEM_SECRET=change-me-hydra-system-secret
HYDRA_SUBJECT_SALT=change-me-hydra-subject-salt
OATHKEEPER_SHARED_SECRET=change-me-oathkeeper-shared-secret
KRATOS_PASSKEY_RP_DISPLAY_NAME=Haruki Toolbox
KRATOS_PASSKEY_RP_ID=haruki.seiunx.com
KRATOS_PASSKEY_RP_ORIGIN=https://haruki.seiunx.com
KRATOS_CODE_MAX_SUBMISSIONS=3
KRATOS_MFA_TOTP_ISSUER=Haruki Toolbox
KRATOS_OIDC_GOOGLE_CLIENT_ID=change-me-google-client-id.apps.googleusercontent.com
KRATOS_OIDC_GOOGLE_CLIENT_SECRET=change-me-google-client-secret
WEBHOOK_JWT_SECRET=change-me-webhook-jwt-secret
SOCIAL_PLATFORM_VERIFY_TOKEN=change-me-social-platform-verify-token
HARUKI_PROXY_USER_AGENT=HarukiProxy
HARUKI_PROXY_VERSION=v1.7.0
HARUKI_PROXY_SECRET=change-me-haruki-proxy-secret
HARUKI_PROXY_UNPACK_KEY=change-me-haruki-proxy-unpack-key
PRIVATE_API_SECRET="Bearer change-me-private-api-secret"
PRIVATE_API_USER_AGENT=Haruki-Cloud
FRONTEND_PUBLIC_URL=https://haruki.seiunx.com
BACKEND_PUBLIC_BASE_URL=https://toolbox-api-direct.haruki.seiunx.com
KRATOS_PUBLIC_BASE_URL=https://toolbox-auth.haruki.seiunx.com
KRATOS_ADMIN_BASE_URL=http://kratos:4434
HYDRA_PUBLIC_BASE_URL=https://toolbox-api-direct.haruki.seiunx.com
ASSET_PUBLIC_BASE_URL=https://images.haruki.seiunx.com
SMTP_CONNECTION_URI=smtps://user%40mail.example.com:password@smtp.example.com:465
SMTP_FROM_ADDRESS=user@mail.example.com
SMTP_FROM_NAME="Haruki工具箱 | 星云科技"
TURNSTILE_BYPASS=true
CLOUDFLARE_SECRET=change-me-cloudflare-secret
BACKEND_AUTO_MIGRATE=true
BACKEND_LOG_LEVEL=INFO
BACKEND_MAIN_LOG_FILE=/app/logs/main.log
BACKEND_ACCESS_LOG="[${time}] ${ip} | ${status} - ${latency} ${method} ${path} (Sent: ${bytesSent})\n"
BACKEND_ACCESS_LOG_PATH=/app/logs/access.log
SEKAI_API_ENDPOINT=change-me-sekai-api-endpoint
SEKAI_API_TOKEN=change-me-sekai-api-token
MIHOMO_PROFILE_NAME=ytoo
KRATOS_ADMIN_UI_PORT=5099
WEBHOOK_ENABLED=true